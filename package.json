{
  "name": "verifymailapi",
  "version": "0.1.1",
  "description": "Official SDK for the VerifyMail API — disposable, throwaway, and abusive email detection.",
  "license": "MIT",
  "homepage": "https://verifymailapi.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jt1402/verifymail-js.git"
  },
  "bugs": {
    "url": "https://github.com/jt1402/verifymail-js/issues"
  },
  "keywords": [
    "email",
    "verification",
    "validation",
    "disposable",
    "throwaway",
    "signup",
    "fraud",
    "verifymail"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "node --test --import=tsx test/**/*.test.ts",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.0",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
